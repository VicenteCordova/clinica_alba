# ── Seguridad ──────────────────────────────────────────────────────────────────
SECRET_KEY=cambia-esta-clave-secreta-en-produccion-ahora-mismo

# DEBUG: True en desarrollo, False en produccion
DEBUG=True

# Hosts permitidos (separados por coma)
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Base de datos MariaDB ──────────────────────────────────────────────────────
DB_NAME=clinica_alba
DB_USER=root
DB_PASSWORD=tu_password_aqui
DB_HOST=127.0.0.1
DB_PORT=3306

# ── Correo (opcional para recuperar acceso) ────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=correo@clinicaelabla.cl
EMAIL_HOST_PASSWORD=password_correo

# ── Archivos ───────────────────────────────────────────────────────────────────
# Tamaño máximo de adjunto clínico en MB
MAX_UPLOAD_MB=10
